{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aces.example/schemas/bundles-app-manual-capture.v1.schema.json",
  "title": "Bundles.app Manual Relationship Capture V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_bundle_id", "product_series_key", "parent_sku", "components"],
  "properties": {
    "schema_version": { "const": "bundles_app_manual_capture.v1" },
    "source_bundle_id": { "type": "string", "minLength": 1 },
    "product_series_key": { "type": "string", "minLength": 1 },
    "parent_sku": { "type": "string", "minLength": 1 },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sku", "quantity"],
        "properties": {
          "sku": { "type": "string", "minLength": 1 },
          "quantity": { "const": 1 }
        }
      }
    },
    "price_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_component_total_cents", "expected_bundle_price_cents"],
      "properties": {
        "expected_component_total_cents": { "type": "integer", "minimum": 0 },
        "expected_bundle_price_cents": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
