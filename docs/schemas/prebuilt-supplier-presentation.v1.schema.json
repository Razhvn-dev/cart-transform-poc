{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aces.example/schemas/prebuilt-supplier-presentation.v1.schema.json",
  "title": "Pre-built Supplier Presentation Input V1",
  "description": "Structural input contract for a local, read-only supplier main-Kit-SKU presentation over internal component Order truth.",
  "$comment": "The JavaScript evaluator is authoritative for cross-record mapping uniqueness, component-to-mapping fulfillment identity agreement, cross-supplier detection, aggregation, and reconciliation trace generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "order", "mappings"],
  "properties": {
    "schema_version": {
      "const": "prebuilt_supplier_presentation.v1"
    },
    "order": {
      "$ref": "#/$defs/internalComponentOrder"
    },
    "mappings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bundleMapping"
      }
    }
  },
  "$defs": {
    "internalComponentOrder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order_id", "component_lines"],
      "properties": {
        "order_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "component_lines": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/componentLine"
          }
        }
      }
    },
    "componentLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line_id",
        "variant_gid",
        "sku",
        "quantity",
        "bundle_instance_id",
        "fulfillment_identity"
      ],
      "properties": {
        "line_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "variant_gid": {
          "$ref": "#/$defs/productVariantGid"
        },
        "sku": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "quantity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "bundle_instance_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "fulfillment_identity": {
          "$ref": "#/$defs/fulfillmentIdentity"
        }
      }
    },
    "bundleMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_instance_id",
        "main_kit_sku",
        "fulfillment_identity",
        "mapping_trace_id"
      ],
      "properties": {
        "bundle_instance_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "main_kit_sku": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "fulfillment_identity": {
          "$ref": "#/$defs/fulfillmentIdentity"
        },
        "mapping_trace_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        }
      }
    },
    "fulfillmentIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["supplier_id", "location_id"],
      "properties": {
        "supplier_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "location_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        }
      }
    },
    "productVariantGid": {
      "type": "string",
      "pattern": "^gid://shopify/ProductVariant/[0-9]+$"
    }
  }
}
