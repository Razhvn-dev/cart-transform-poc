{% doc %}
Renders the POC product builder for the Master Kit product page.
@example
{% content_for 'block', type: 'product-builder', id: 'product-builder' %}
{% enddoc %}

{% liquid
  assign fallback_master_variant_id = '51505325605142'
  assign fuel_variant_gid = 'gid://shopify/ProductVariant/51505348346134'
  assign fuel_test_2_variant_gid = 'gid://shopify/ProductVariant/51518319591702'

  assign master_product = block.settings.master_product
  if master_product == blank
    assign master_product = product
  endif
  if master_product == blank
    assign master_product = all_products['master-kit-test']
  endif

  assign fuel_product = all_products['fuel-test']
  assign fuel_test_2_product = all_products['fuel-test-2']
  assign efi_fusion_lite_product = all_products['killshot-fusion-lite-efi-system']
  assign efi_killshot_2_pro_product = all_products['aces-efi-killshot-tbi-system']
  assign ignition_black_jack_product = all_products['black-jack-pro-series-ignition-coil']
  assign ignition_high_roller_product = all_products['high-roller-cdi-ignition-box']
  assign display_5_hd_product = all_products['5-pro-handheld']
  assign display_8_hd_product = all_products['8-handheld']

  assign master_variant = master_product.selected_or_first_available_variant
  assign fuel_variant = fuel_product.selected_or_first_available_variant
  assign fuel_test_2_variant = fuel_test_2_product.selected_or_first_available_variant
  assign efi_fusion_lite_variant = efi_fusion_lite_product.selected_or_first_available_variant
  assign efi_killshot_2_pro_variant = efi_killshot_2_pro_product.selected_or_first_available_variant
  assign ignition_black_jack_variant = ignition_black_jack_product.selected_or_first_available_variant
  assign ignition_high_roller_variant = ignition_high_roller_product.selected_or_first_available_variant
  assign display_5_hd_variant = display_5_hd_product.selected_or_first_available_variant
  assign display_8_hd_variant = display_8_hd_product.selected_or_first_available_variant

  assign fuel_main_image = fuel_product | image_url: width: 480
  assign fuel_test_2_main_image = fuel_test_2_product | image_url: width: 480
  assign efi_fusion_lite_main_image = efi_fusion_lite_product | image_url: width: 480
  assign efi_killshot_2_pro_main_image = efi_killshot_2_pro_product | image_url: width: 480
  assign ignition_black_jack_main_image = ignition_black_jack_product | image_url: width: 480
  assign ignition_high_roller_main_image = ignition_high_roller_product | image_url: width: 480
  assign display_5_hd_main_image = display_5_hd_product | image_url: width: 480
  assign display_8_hd_main_image = display_8_hd_product | image_url: width: 480

  assign master_variant_id = fallback_master_variant_id
  if master_variant.id != blank
    assign master_variant_id = master_variant.id
  endif

  assign fuel_price_cents = fuel_variant.price | default: 0
  assign fuel_test_2_price_cents = fuel_test_2_variant.price | default: 0
  assign fuel_adjustment_cents = fuel_price_cents
  assign fuel_test_2_adjustment_cents = fuel_test_2_price_cents
  assign efi_fusion_lite_price_cents = efi_fusion_lite_variant.price | default: 0
  assign efi_killshot_2_pro_price_cents = efi_killshot_2_pro_variant.price | default: 0
  assign ignition_black_jack_price_cents = ignition_black_jack_variant.price | default: 0
  assign ignition_high_roller_price_cents = ignition_high_roller_variant.price | default: 0
  assign display_5_hd_price_cents = display_5_hd_variant.price | default: 0
  assign display_8_hd_price_cents = display_8_hd_variant.price | default: 0
  assign bundle_discount_basis_points = 500
  assign builder_base_price_cents = 0
  assign default_configuration_total_cents = efi_fusion_lite_price_cents | plus: fuel_adjustment_cents | plus: ignition_black_jack_price_cents
  assign default_bundle_discount_cents = default_configuration_total_cents | times: bundle_discount_basis_points | plus: 5000 | divided_by: 10000
  assign default_final_total_cents = default_configuration_total_cents | minus: default_bundle_discount_cents
%}

